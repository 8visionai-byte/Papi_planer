// prisma/schema.prisma
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          UserRole  @default(USER)
  googleId      String?   @unique @map("google_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  profile       UserProfile?
  lifeAreas     LifeArea[]
  mentors       Mentor[]
  dailyLogs     DailyLog[]
  weeklyCheckins WeeklyCheckin[]
  roundTableSessions RoundTableSession[]
  briefings     Briefing[]
  files         UserFile[]
  schedules     Schedule[]
  feedback      Feedback[]
  goals         Goal[]
  mentorPlans   MentorPlan[]
  trainingLogs  TrainingLog[]
  personalRecords PersonalRecord[]
  weightEntries WeightEntry[]
  habits        Habit[]
  journalEntries     JournalEntry[]
  journalAgentConfig JournalAgentConfig?
  meetingCompletions MeetingCompletion[]
  mentorConversations MentorConversation[]

  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  data   Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model LifeArea {
  id          String  @id @default(cuid())
  userId      String  @map("user_id")
  name        String
  slug        String?
  category    String?
  description String? @db.Text
  priority    Int     @default(0)
  active      Boolean @default(true)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentors    Mentor[]   @relation("MentorLifeAreas")
  activities Activity[]
  schedules  Schedule[]
  goals      Goal[]
  trainingLogs TrainingLog[]
  personalRecords PersonalRecord[]

  @@map("life_areas")
}

model TrainingLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  lifeAreaId String   @map("life_area_id")
  date       DateTime @default(now())
  exerciseName String @map("exercise_name")
  sets       Int?
  reps       Int?
  weightKg   Float?   @map("weight_kg")
  durationMin Int?    @map("duration_min")
  distance   Float?
  notes      String?  @db.Text
  rating     Int?
  metrics    Json?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeArea LifeArea @relation(fields: [lifeAreaId], references: [id], onDelete: Cascade)

  @@index([userId, lifeAreaId, date])
  @@map("training_logs")
}

model PersonalRecord {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  lifeAreaId String   @map("life_area_id")
  exerciseName String @map("exercise_name")
  value      Float
  unit       String
  achievedAt DateTime @default(now()) @map("achieved_at")
  notes      String?  @db.Text

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeArea LifeArea @relation(fields: [lifeAreaId], references: [id], onDelete: Cascade)

  @@index([userId, lifeAreaId])
  @@map("personal_records")
}

model Mentor {
  id           String  @id @default(cuid())
  userId       String  @map("user_id")
  name         String
  role         String
  persona      String  @db.Text
  systemPrompt String  @map("system_prompt") @db.Text
  style        String?
  model        String  @default("claude-sonnet-4-6")
  active       Boolean @default(true)
  sortOrder    Int     @default(0) @map("sort_order")
  avatarEmoji  String? @default("🧑‍🏫") @map("avatar_emoji")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeAreas   LifeArea[]   @relation("MentorLifeAreas")
  goals       Goal[]
  mentorPlans MentorPlan[]
  conversations MentorConversation[]

  @@map("mentors")
}

model MentorConversation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  mentorId  String   @map("mentor_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentor   Mentor              @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  messages MentorChatMessage[]

  @@index([userId, mentorId, updatedAt])
  @@map("mentor_conversations")
}

model MentorChatMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  conversation MentorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("mentor_chat_messages")
}

model DailyLog {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  date              DateTime @db.Date
  dayType           String?  @map("day_type")
  energy            Int?
  sleepHours        Float?   @map("sleep_hours")
  sleepQuality      Int?     @map("sleep_quality")
  mood              String?
  voiceTranscript   String?  @map("voice_transcript") @db.Text
  protocolActivated String?  @map("protocol_activated")
  createdAt         DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities Activity[]
  meals      Meal[]

  @@unique([userId, date])
  @@map("daily_logs")
}

model Activity {
  id          String  @id @default(cuid())
  dailyLogId  String  @map("daily_log_id")
  lifeAreaId  String? @map("life_area_id")
  type        String
  name        String
  scheduledAt String? @map("scheduled_at")
  durationMin Int?    @map("duration_min")
  completed   Boolean @default(false)
  metrics     Json?
  notes       String? @db.Text

  dailyLog DailyLog  @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  lifeArea LifeArea? @relation(fields: [lifeAreaId], references: [id], onDelete: SetNull)

  @@map("activities")
}

model Meal {
  id          String @id @default(cuid())
  dailyLogId  String @map("daily_log_id")
  time        String
  name        String
  calories    Int?
  protein     Float?
  carbs       Float?
  fat         Float?
  description String?

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@map("meals")
}

model WeeklyCheckin {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  weekNumber   Int      @map("week_number")
  date         DateTime @db.Date
  weight       Float?
  measurements Json?
  areaStats    Json?    @map("area_stats")
  energyAvg    Float?   @map("energy_avg")
  wins         String?  @db.Text
  fails        String?  @db.Text
  mentorNotes  Json?    @map("mentor_notes")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekNumber])
  @@map("weekly_checkins")
}

model RoundTableSession {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  inputText        String   @map("input_text") @db.Text
  inputType        String   @default("text") @map("input_type")
  consensus        String?  @db.Text
  debateTranscript Json?    @map("debate_transcript")
  planChanges      Json?    @map("plan_changes")
  applied          Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("round_table_sessions")
}

model Briefing {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  date     DateTime @db.Date
  content  String   @db.Text
  audioUrl String?  @map("audio_url") @db.Text
  phase    Int?
  week     Int?
  dayType  String?  @map("day_type")
  finalized Boolean @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("briefings")
}

model UserFile {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  filename  String
  path      String
  mimeType  String   @map("mime_type")
  size      Int
  analysis  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("files")
}

model Schedule {
  id           String  @id @default(cuid())
  userId       String  @map("user_id")
  dayOfWeek    Int     @map("day_of_week")
  time         String
  activityName String  @map("activity_name")
  lifeAreaId   String? @map("life_area_id")
  recurring    Boolean @default(true)
  notes        String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeArea LifeArea? @relation(fields: [lifeAreaId], references: [id], onDelete: SetNull)

  @@map("schedules")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   @default("change")
  message   String   @db.Text
  status    String   @default("new")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

model Goal {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  mentorId    String?   @map("mentor_id")
  mentorIds   String[]  @default([]) @map("mentor_ids")
  lifeAreaId  String?   @map("life_area_id")
  title       String
  description String?   @db.Text
  targetDate  DateTime? @map("target_date") @db.Date
  status      String    @default("active")
  progress    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentor      Mentor?         @relation(fields: [mentorId], references: [id], onDelete: SetNull)
  lifeArea    LifeArea?       @relation(fields: [lifeAreaId], references: [id], onDelete: SetNull)
  milestones  GoalMilestone[]
  mentorPlans MentorPlan[]

  @@map("goals")
}

model GoalMilestone {
  id        String  @id @default(cuid())
  goalId    String  @map("goal_id")
  title     String
  completed Boolean @default(false)
  sortOrder Int     @default(0) @map("sort_order")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("goal_milestones")
}

model MentorPlan {
  id         String  @id @default(cuid())
  mentorId   String  @map("mentor_id")
  userId     String  @map("user_id")
  goalId     String? @map("goal_id")
  weekNumber Int     @map("week_number")
  phase      Int     @default(1)
  tasks      Json
  notes      String? @db.Text

  mentor Mentor @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal   Goal?  @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, mentorId, weekNumber])
  @@index([userId])
  @@map("mentor_plans")
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  role      UserRole @default(USER)
  addedBy   String?  @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("allowed_emails")
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  weightKg  Float    @map("weight_kg")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("weight_entries")
}

model Habit {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?
  timeOfDay   String   @default("any") @map("time_of_day")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitCompletion[]

  @@index([userId, active])
  @@map("habits")
}

model HabitCompletion {
  id        String   @id @default(cuid())
  habitId   String   @map("habit_id")
  userId    String   @map("user_id")
  date      DateTime @db.Date
  completed Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
  @@map("habit_completions")
}

model JournalEntry {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  rawText      String   @db.Text @map("raw_text")
  redactedText String?  @db.Text @map("redacted_text")
  category     String?  // "Myśl" | "Refleksja" | "Wniosek" | "Doświadczenie"
  topic        String?  // "zdrowie" | "dzieci" | "dziewczyna" | "biznes" | "inne"
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("journal_entries")
}

model JournalAgentConfig {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  systemPrompt String   @db.Text @map("system_prompt")
  model        String   @default("claude-sonnet-4-6")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("journal_agent_config")
}

model MeetingCompletion {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  externalId  String   @map("external_id")
  date        DateTime @db.Date
  completedAt DateTime @default(now()) @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId, date])
  @@index([userId, date])
  @@map("meeting_completions")
}
